# Porta em que o servidor backend irá rodar (padrão: 3001)
PORT=3001

# Ambiente de execução ('production' ou 'development')
NODE_ENV=production

# Chave de criptografia para o cofre de senhas (ESSENCIAL em produção)
# Altere para uma chave secreta forte. Caso seja alterada após dados existirem no banco,
# o cofre não conseguirá descriptografar os dados salvos anteriormente.
ENCRYPTION_KEY=poupa_pila_super_secure_key_32_bytes_long!

# Caminho customizado para o arquivo do banco de dados SQLite (opcional)
# DATABASE_PATH=./poupa_pila.db

# Origens permitidas para requisições CORS separadas por vírgula (padrão: * se não definido)
# ALLOWED_ORIGINS=http://localhost:5173
